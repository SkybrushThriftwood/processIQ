---
title: ProcessIQ High-Level Architecture
---
flowchart TB
    classDef browser fill:#EAF2FF,stroke:#3563B7,stroke-width:2px,color:#111
    classDef api fill:#EAF8EE,stroke:#2E8B57,stroke-width:2px,color:#111
    classDef ai fill:#FFF4D6,stroke:#B8860B,stroke-width:2px,color:#111
    classDef storage fill:#F4EAFF,stroke:#7A3DB8,stroke-width:2px,color:#111

    subgraph BROWSER["User & Browser"]
        direction TB
        USER["User"]:::browser
        APP["Next.js + React<br/>Chat, step editor, results, library"]:::browser
    end

    subgraph BACKEND["API & Orchestration"]
        direction TB
        API["FastAPI<br/>Validation, rate limiting, response shaping"]:::api
        AGENT["LangGraph Agent<br/>Extraction -> Analysis -> Investigation<br/>See agent_flow.mmd for detail"]:::ai
    end

    subgraph STORAGE["Storage & Cache"]
        direction LR
        SQLITE["SQLite<br/>Profiles, sessions,<br/>feedback, checkpoints"]:::storage
        CHROMA["ChromaDB<br/>Semantic retrieval<br/>of past analyses"]:::storage
        CACHE["In-memory cache<br/>Active graph and<br/>CSV session data"]:::storage
    end

    %% Primary request path - thick arrows
    USER ==> APP
    APP ==> API
    API ==> AGENT

    %% Persistence - normal weight
    AGENT <--> SQLITE
    AGENT <--> CHROMA
    API <--> CACHE

    %% Feedback loop - muted
    APP -. "feedback submission" .-> API
    API -. "re-analysis with feedback context" .-> AGENT

    %% Session reads - muted
    API -. "session and profile reads" .-> SQLITE
